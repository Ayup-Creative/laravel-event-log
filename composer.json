{
    "name": "ayup-creative/event-log",
    "description": "Event log package for models in a Laravel application.",
    "require-dev": {
        "phpunit/phpunit": "^11",
        "laravel/pint": "^1.0",
        "laravel/framework": "^12|^13.0",
        "orchestra/testbench": "^v11.0"
    },
    "autoload": {
        "psr-4": {
            "AyupCreative\\EventLog\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "AyupCreative\\EventLog\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AyupCreative\\EventLog\\EventLogServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "pint": "vendor/bin/pint"
    }
}
